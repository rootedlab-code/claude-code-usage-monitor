/*
 * Copy this file to `secrets.h` (same directory).
 *
 *   cp src/secrets.h.template src/secrets.h
 *
 * v0.2: these values are FALLBACKS. The captive portal at runtime lets end
 * users configure all fields via web form (config persisted to NVS); leave
 * them empty for a binary release. Fill them in only if you want a fully
 * compile-time configuration ("source build" path, no portal needed).
 *
 * `secrets.h` is in .gitignore and must NEVER be committed.
 */
#pragma once

// ----- WiFi credentials (fallback) -----
#define WIFI_SSID          ""
#define WIFI_PASS          ""

// ----- Bridge endpoint (fallback) -----
// IP of the machine running `bridge/bridge.py`. The bridge prints this IP at
// startup. Must be reachable from the ESP32 on the same LAN.
#define BRIDGE_HOST        ""
#define BRIDGE_PORT        8787

// ----- Bridge bearer token (fallback) -----
// Paste the value bridge.py prints at startup (line "token: ...").
// Leave empty only if the bridge is run with --no-auth.
#define BRIDGE_TOKEN       ""

// ----- Polling cadence (milliseconds) -----
// How often the ESP32 fetches /usage from the bridge. 5 seconds is a good
// default: low CPU/RAM cost on the bridge, near-realtime on the display.
#define POLL_INTERVAL_MS   5000
