#pragma once

// ----- WiFi credentials -----
#define WIFI_SSID          "your-wifi-ssid"
#define WIFI_PASS          "your-wifi-password"

// ----- Bridge endpoint -----
// IP of the machine running `bridge/bridge.py`. The bridge prints
// this IP at startup. Must be reachable from the ESP32 on the same LAN.
#define BRIDGE_HOST        "192.168.1.42"
#define BRIDGE_PORT        8787

// ----- Polling cadence (milliseconds) -----
// How often the ESP32 fetches /usage from the bridge. 5 seconds is a good
// default: low CPU/RAM cost on the bridge, near-realtime on the display.
#define POLL_INTERVAL_MS   5000
